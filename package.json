{
  "name": "pickgauge",
  "version": "0.1.1",
  "description": "The Pickforge AI usage tray for Codex and Claude Code.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint src scripts sidecars vite.config.ts",
    "smoke:kde-tray": "node scripts/validate-kde-tray-registration.mjs",
    "smoke:auth-profile": "node scripts/validate-playwright-authenticated-profile.mjs",
    "smoke:preflight": "node scripts/collect-smoke-preflight.mjs",
    "prepare:sidecar": "node scripts/prepare-playwright-sidecar.mjs",
    "test:installer": "node tests/install-script-smoke.mjs",
    "test": "node tests/install-script-smoke.mjs && vitest run && node --test sidecars/playwright/*.node-test.mjs && node scripts/prepare-playwright-sidecar.mjs --check && node scripts/validate-playwright-sidecar-package.mjs",
    "test:coverage": "vitest run --coverage",
    "test:browser-preview": "node scripts/validate-browser-preview.mjs",
    "test:auth-profile-helper": "node scripts/validate-playwright-auth-profile-helper.mjs",
    "test:official-fail-closed": "node scripts/validate-playwright-official-fail-closed.mjs",
    "test:synthetic-fail-closed": "node scripts/validate-playwright-synthetic-fail-closed.mjs",
    "test:sidecar-launch": "node scripts/validate-playwright-sidecar-launch.mjs",
    "tauri": "tauri",
    "build:appimage": "bun run prepare:sidecar && NO_STRIP=1 tauri build --bundles appimage"
  },
  "dependencies": {
    "@pickforge/brand": "0.2.1",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "phosphor-svelte": "^3.1.0",
    "playwright": "^1.60.0",
    "svelte": "^5.43.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@pickforge/tauri-release": "0.1.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tauri-apps/cli": "^2.9.3",
    "@tsconfig/svelte": "^5.0.5",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.2.4",
    "vitest": "^4.1.8"
  }
}
