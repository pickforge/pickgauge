#!/usr/bin/env bash
set -euo pipefail

# Installs the PickGauge desktop entry and icons. Wayland compositors show
# window icons by matching the window's app_id ("pickgauge") to an installed
# .desktop file — without this, KDE shows the generic Wayland icon.

REPO_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
APP_BIN="${1:-$REPO_DIR/src-tauri/target/release/pickgauge}"
ICON_ROOT="$HOME/.local/share/icons/hicolor"
APPS_DIR="$HOME/.local/share/applications"

for size in 32 64 128 256 512; do
  install -Dm644 "$REPO_DIR/assets/branding/pickgauge-app-icon-${size}.png" \
    "$ICON_ROOT/${size}x${size}/apps/pickgauge.png"
done

mkdir -p "$APPS_DIR"
cat > "$APPS_DIR/pickgauge.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=PickGauge
GenericName=AI usage tray
Comment=The Pickforge AI usage tray for Codex and Claude Code
Exec=$APP_BIN
Icon=pickgauge
Terminal=false
Categories=Utility;Monitor;
Keywords=usage;quota;codex;claude;
StartupWMClass=Pickgauge
EOF

command -v update-desktop-database >/dev/null 2>&1 && update-desktop-database "$APPS_DIR" || true
command -v gtk-update-icon-cache >/dev/null 2>&1 && gtk-update-icon-cache -q "$ICON_ROOT" 2>/dev/null || true

echo "PickGauge desktop integration installed (restart the app to pick up the icon)."
